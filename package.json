{
  "name": "weblinuxos",
  "version": "1.0.0",
  "private": true,
  "description": "A web-based Linux-like OS with 56+ apps",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/web",
    "build": "npm run build -ws --if-present",
    "preview": "npm run preview -w apps/web",
    "lint": "npm run lint -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present"
  },
  "keywords": [
    "weblinux",
    "webos",
    "linux",
    "react",
    "typescript",
    "vite"
  ],
  "author": "",
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.2.70",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.10"
  },
  "dependencies": {
    "dexie": "^4.0.1",
    "lucide-react": "^0.365.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "zustand": "^4.5.2"
  }
}
