{
  "name": "weblinuxos",
  "private": true,
  "version": "7.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:local": "tsc -b && VITE_BASE_PATH=/ vite build",
    "build:github": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rm -rf ../dist ../assets ../index.html ../favicon.svg ../icons.svg ../.nojekyll ../manifest.json ../screenshots",
    "predeploy": "npm run clean",
    "deploy": "npm run build:github",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "preinstall": "npx only-allow npm"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "pyodide": "^0.26.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/marked": "^5.0.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "terser": "^5.27.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.12"
  }
}
